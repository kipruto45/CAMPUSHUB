# =============================================================================
# CampusHub Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# Django Settings
# In production this must be a high-entropy secret with at least 50 characters.
SECRET_KEY=your-super-secret-key-change-in-production
DEBUG=False
ENVIRONMENT=production
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com
CSRF_TRUSTED_ORIGINS=https://your-domain.com,https://api.your-domain.com
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000

# Database
POSTGRES_DB=campushub
POSTGRES_USER=campushub
POSTGRES_PASSWORD=change-this-password
DB_NAME=campushub
DB_USER=campushub
DB_PASSWORD=change-this-password
DB_HOST=localhost
DB_PORT=5432
# Optional single-string override (takes precedence over DB_* and POSTGRES_*):
# DATABASE_URL=postgresql://campushub:change-this-password@localhost:5432/campushub

# Redis (leave blank to disable)
REDIS_URL=
# Cache backend (locmem recommended unless you provision Redis)
CACHE_BACKEND=locmem

# Email (SMTP)
# For real delivery in development/production set:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# AWS S3 (for file storage)
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_STORAGE_BUCKET_NAME=campushub-bucket
AWS_S3_REGION_NAME=us-east-1

# Cloudinary (optional media storage)
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
# Set to True to enable Cloudinary storage, otherwise local media storage is used.
CLOUDINARY_ENABLED=False

# Firebase Cloud Messaging (FCM) - Android
FCM_ENABLED=False
FCM_SERVER_KEY=your-firebase-server-key
FCM_PROJECT_ID=your-firebase-project-id

# Apple Push Notification Service (APNs) - iOS
APNS_ENABLED=False
APNS_KEY_ID=your-apns-key-id
APNS_TEAM_ID=your-team-id
APNS_BUNDLE_ID=com.campushub.app
APNS_AUTH_KEY_PATH=/app/keys/AuthKey.p8
APNS_AUTH_KEY=your-base64-encoded-key
APNS_ENVIRONMENT=production

# CORS (for mobile apps)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081,https://your-domain.com

# JWT Settings
JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=30

# Celery (leave empty to avoid Redis)
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# Django Channels
# Use `inmemory` unless you provision Redis.
CHANNEL_LAYER_BACKEND=inmemory

# Application Version
MOBILE_API_VERSION=1.0

# Static/Media URLs (use CDN if available)
# Example CDN: https://cdn.your-domain.com/static/ and https://cdn.your-domain.com/media/
STATIC_URL=/static/
MEDIA_URL=/media/

# =============================================================================
# Mobile App (Expo / React Native)
# Used by mobile/src/services/api.ts
# Examples:
#   Android emulator: http://10.0.2.2:8000/api
#   iOS simulator:     http://127.0.0.1:8000/api
#   Physical device:   http://<your-lan-ip>:8000/api
# =============================================================================
EXPO_PUBLIC_API_URL=http://127.0.0.1:8000/api
EXPO_PUBLIC_NOTIFICATION_UNDO_MS=4000

# Frontend URL - used for password reset & email verification links
# Set this to your web frontend URL (e.g., https://campushub.com)
# If not set, the system will try to use mobile deep links instead
FRONTEND_URL=https://campushub.com

# Deep Links / Universal Links / App Links
MOBILE_DEEPLINK_SCHEME=campushub
MOBILE_DEEPLINK_HOST=campushub.com
RESOURCE_SHARE_BASE_URL=https://campushub.com

# Android App Links
ANDROID_APP_PACKAGE=com.campushub.app
ANDROID_SHA256_CERT_FINGERPRINTS=AA:BB:CC:DD:...:ZZ

# iOS Universal Links
IOS_TEAM_ID=YOUR_APPLE_TEAM_ID
IOS_BUNDLE_ID=com.campushub.app

# Admin bootstrap (used by: python manage.py ensure_superuser)
DJANGO_SUPERUSER_EMAIL=admin@campushub.com
DJANGO_SUPERUSER_PASSWORD=change-this-admin-password
DJANGO_SUPERUSER_FULL_NAME=CampusHub Admin
DJANGO_SUPERUSER_UPDATE_PASSWORD=False

# =============================================================================
# Social Authentication (OAuth2)
# Configure Google and Microsoft OAuth for mobile app social login
# =============================================================================
# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Must be registered in Google Cloud Console Authorized redirect URIs
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback/

# Native Google Sign-In (mobile SDKs)
# Web client ID is required to obtain an ID token on Android.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your-google-android-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-google-ios-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_URL_SCHEME=com.googleusercontent.apps.your-ios-client-id

# Microsoft OAuth
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
# Must be registered in Microsoft Entra redirect URIs
MICROSOFT_REDIRECT_URI=http://localhost:8000/api/auth/microsoft/callback/
MICROSOFT_TENANT_ID=common

# Native Microsoft Sign-In (MSAL)
EXPO_PUBLIC_MICROSOFT_CLIENT_ID=your-microsoft-client-id
EXPO_PUBLIC_MICROSOFT_TENANT_ID=common
EXPO_PUBLIC_MICROSOFT_REDIRECT_URI=msauth://com.example/your_signature_hash
EXPO_PUBLIC_MICROSOFT_ANDROID_SIGNATURE_HASH=your_signature_hash
