# =============================================================================
# CampusHub Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# Django Settings
# In production this must be a high-entropy secret with at least 50 characters.
SECRET_KEY=your-super-secret-key-change-in-production
DEBUG=False
ENVIRONMENT=production
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com
CSRF_TRUSTED_ORIGINS=https://your-domain.com,https://api.your-domain.com
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000

# Database
# Local default sqlite database URL. In production, prefer a managed Postgres URL.
DATABASE_URL=sqlite:////tmp/campushub.sqlite3
# Keep False on Render; migrations already run in build/deploy steps.
AUTO_MIGRATE_ON_STARTUP=False

# Redis (leave blank to disable)
REDIS_URL=
# Cache backend (locmem recommended unless you provision Redis)
CACHE_BACKEND=locmem

# Email (SMTP)
# For real delivery in development/production set:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# AWS S3 (for file storage)
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_STORAGE_BUCKET_NAME=campushub-bucket
AWS_S3_REGION_NAME=us-east-1

# Cloudinary (optional media storage)
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
# Set to True to enable Cloudinary storage, otherwise local media storage is used.
CLOUDINARY_ENABLED=False

# Firebase Cloud Messaging (FCM) - Android
FCM_ENABLED=False
FCM_SERVER_KEY=your-firebase-server-key
FCM_PROJECT_ID=your-firebase-project-id

# Apple Push Notification Service (APNs) - iOS
APNS_ENABLED=False
APNS_KEY_ID=your-apns-key-id
APNS_TEAM_ID=your-team-id
APNS_BUNDLE_ID=com.campushub.app
APNS_AUTH_KEY_PATH=/app/keys/AuthKey.p8
APNS_AUTH_KEY=your-base64-encoded-key
APNS_ENVIRONMENT=production

# CORS (for mobile apps)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081,https://your-domain.com

# JWT Settings
JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=30

# Celery (leave empty to avoid Redis)
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# Django Channels
# Use `inmemory` unless you provision Redis.
CHANNEL_LAYER_BACKEND=inmemory

# Application Version
MOBILE_API_VERSION=1.0

# Static/Media URLs (use CDN if available)
# Example CDN: https://cdn.your-domain.com/static/ and https://cdn.your-domain.com/media/
STATIC_URL=/static/
MEDIA_URL=/media/

# =============================================================================
# Mobile App (Expo / React Native)
# Used by mobile/src/services/api.ts
# Examples:
#   Android emulator: http://10.0.2.2:8000/api
#   iOS simulator:     http://127.0.0.1:8000/api
#   Physical device:   http://<your-lan-ip>:8000/api
# =============================================================================
EXPO_PUBLIC_API_URL=http://127.0.0.1:8000/api
EXPO_PUBLIC_NOTIFICATION_UNDO_MS=4000

# Frontend URL - used for password reset & email verification links
# Set this to your web frontend URL (e.g., https://campushub.com)
# If not set, the system will try to use mobile deep links instead
FRONTEND_URL=https://campushub.com

# Deep Links / Universal Links / App Links
MOBILE_DEEPLINK_SCHEME=campushub
MOBILE_DEEPLINK_HOST=campushub.com
RESOURCE_SHARE_BASE_URL=https://campushub.com

# Android App Links
ANDROID_APP_PACKAGE=com.campushub.app
ANDROID_SHA256_CERT_FINGERPRINTS=AA:BB:CC:DD:...:ZZ

# iOS Universal Links
IOS_TEAM_ID=YOUR_APPLE_TEAM_ID
IOS_BUNDLE_ID=com.campushub.app

# Admin bootstrap (used by: python manage.py ensure_superuser)
DJANGO_SUPERUSER_EMAIL=admin@campushub.com
DJANGO_SUPERUSER_PASSWORD=change-this-admin-password
DJANGO_SUPERUSER_FULL_NAME=CampusHub Admin
DJANGO_SUPERUSER_UPDATE_PASSWORD=False

# =============================================================================
# Social Authentication (OAuth2)
# Configure Google and Microsoft OAuth for mobile app social login
# =============================================================================
# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Must be registered in Google Cloud Console Authorized redirect URIs
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback/

# Native Google Sign-In (mobile SDKs)
# Web client ID is required to obtain an ID token on Android.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your-google-android-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-google-ios-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_URL_SCHEME=com.googleusercontent.apps.your-ios-client-id

# Microsoft OAuth
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
# Must be registered in Microsoft Entra redirect URIs
MICROSOFT_REDIRECT_URI=http://localhost:8000/api/auth/microsoft/callback/
MICROSOFT_TENANT_ID=common

# Microsoft Teams Integration OAuth (can use same credentials as above)
MICROSOFT_OAUTH_CLIENT_ID=your-microsoft-client-id
MICROSOFT_OAUTH_CLIENT_SECRET=your-microsoft-client-secret
MICROSOFT_TEAMS_REDIRECT_URI=http://localhost:8000/api/integrations/microsoft-teams/oauth/callback/

# Native Microsoft Sign-In (MSAL)
EXPO_PUBLIC_MICROSOFT_CLIENT_ID=your-microsoft-client-id
EXPO_PUBLIC_MICROSOFT_TENANT_ID=common
EXPO_PUBLIC_MICROSOFT_REDIRECT_URI=msauth://com.example/your_signature_hash
EXPO_PUBLIC_MICROSOFT_ANDROID_SIGNATURE_HASH=your_signature_hash

# =============================================================================
# AI Assistant Configuration
# Optional: when OPENAI_API_KEY is set, CampusHub AI can answer like a mini ChatGPT
# while still using CampusHub resource context.
# =============================================================================
OPENAI_API_KEY=
AI_CHAT_MODEL=gpt-4o-mini
AI_CHAT_TEMPERATURE=0.4
AI_CHAT_MAX_TOKENS=500
AI_CHAT_TIMEOUT_SECONDS=25
SUMMARIZATION_MODEL=gpt-4o-mini

# =============================================================================
# Payment Provider Configuration
# Multi-provider payment support: Stripe, PayPal, Mobile Money
# =============================================================================

# Stripe Payment Settings
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# PayPal Payment Settings
PAYPAL_MODE=sandbox  # sandbox or production
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret

# Mobile Money Settings (e.g., M-Pesa)
MOBILE_MONEY_PROVIDER=mpesa  # mpesa, airtel, etc.
MOBILE_MONEY_SHORT_CODE=your_short_code
MOBILE_MONEY_CONSUMER_KEY=your_consumer_key
MOBILE_MONEY_CONSUMER_SECRET=your_consumer_secret
MOBILE_MONEY_PASSKEY=your_mpesa_stk_passkey
MOBILE_MONEY_ENV=sandbox  # sandbox or production
MOBILE_MONEY_TRANSACTION_TYPE=CustomerPayBillOnline
MOBILE_MONEY_CALLBACK_URL=https://api.campushub.com/api/payments/webhook/mobile-money/
# Optional override (defaults based on MOBILE_MONEY_ENV)
MOBILE_MONEY_API_BASE_URL=
MOBILE_MONEY_TIMEOUT_SECONDS=30

# Base URL for payment redirects (must be accessible from payment providers)
BASE_URL=https://campushub.com

# Payment feature toggle
PAYMENTS_ENABLED=True

# =============================================================================
# SMS Notification Settings
# Configure SMS provider for payment notifications (Twilio, Africa's Talking, etc.)
# =============================================================================

# SMS Provider: twilio, africastalking, or generic
SMS_PROVIDER=twilio

# Twilio SMS Settings
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Africa's Talking SMS Settings
AFRICAS_TALKING_USERNAME=your_username
AFRICAS_TALKING_API_KEY=your_api_key
AFRICAS_TALKING_SHORT_CODE=your_short_code

# Generic SMS API Settings
SMS_API_URL=https://api.example.com/sms
SMS_API_KEY=your_api_key
SMS_SENDER_ID=CampusHub

# =============================================================================
# Encryption Configuration
# End-to-end encryption for sensitive data at rest (grades, personal information)
# =============================================================================
# Enable encryption feature (set to True in production)
ENCRYPTION_ENABLED=False

# Master key for AES-256-GCM encryption
# Must be 64 hex characters (32 bytes) for AES-256
# Generate with: python -c "import os; print(os.urandom(32).hex())"
ENCRYPTION_MASTER_KEY=

# Salt for key derivation (should be unique per deployment)
ENCRYPTION_KEY_SALT=campushub-default-salt-change-in-production

# Allow unencrypted fallback for migration purposes
ENCRYPTION_ALLOW_FALLBACK=True

# Current key version (increment when rotating keys)
ENCRYPTION_KEY_VERSION=1

# Previous master keys for key rotation (format: version:hex_key)
# Example: ENCRYPTION_PREVIOUS_KEYS="1:oldmasterkey,2:oldermasterkey"
ENCRYPTION_PREVIOUS_KEYS=

# =============================================================================
# Analytics & observability
ANALYTICS_HMAC_SECRET=change-me-analytics-hmac
ANALYTICS_SAMPLE_RATE=1.0
LOG_LEVEL=INFO
LOG_FILE=logs/campushub.log
